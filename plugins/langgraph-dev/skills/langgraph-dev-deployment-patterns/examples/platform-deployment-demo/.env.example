# LangSmith API Key (required)
# Get from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_your_api_key_here

# Anthropic API Key (for LLM calls)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# Deployment URL (after deploying to Platform)
# Format: https://your-deployment.langchain.com
DEPLOYMENT_URL=https://your-deployment.langchain.com

# LangSmith Tracing (optional, default: true)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=platform-deployment-demo

# For self-hosted deployments only
# REDIS_URI=redis://localhost:6379/0
# DATABASE_URI=postgres://user:pass@localhost:5432/langgraph?sslmode=disable
# LANGGRAPH_CLOUD_LICENSE_KEY=your_license_key
